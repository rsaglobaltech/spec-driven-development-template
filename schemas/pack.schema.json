{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-driven.dev/schemas/pack/v1.json",
  "title": "Domain Pack",
  "description": "Schema for create-spec-driven-app domain pack files (pack.yaml).",
  "type": "object",
  "required": [
    "schema_version",
    "metadata",
    "variables",
    "requirements",
    "outputs",
    "rules"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "SemVer version of the pack.yaml schema.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version", "language", "project_type"],
      "additionalProperties": false,
      "properties": {
        "name":         { "type": "string", "minLength": 1 },
        "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "language":     { "type": "string", "pattern": "^[a-z]{2}$" },
        "project_type": { "type": "string", "enum": ["backend", "frontend", "contracts"] }
      }
    },
    "variables": {
      "type": "object",
      "required": ["required"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[A-Z_]+$" }
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "priority", "description", "status"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^REQ-\\d+$" },
          "title":       { "type": "string", "minLength": 1 },
          "priority":    { "type": "string", "enum": ["Must", "Should", "Could", "Won't"] },
          "description": { "type": "string", "minLength": 1 },
          "status":      { "$ref": "#/$defs/status" }
        }
      }
    },
    "bounded_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "responsibility", "aggregates"],
        "additionalProperties": false,
        "properties": {
          "id":             { "type": "string", "pattern": "^BC-\\d+$" },
          "name":           { "type": "string", "minLength": 1 },
          "type":           { "type": "string", "enum": ["Core", "Supporting", "Generic"] },
          "responsibility": { "type": "string", "minLength": 1 },
          "aggregates":     { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "actor", "requirement", "aggregate", "emits", "scenarios", "status"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^UC-\\d+$" },
          "name":        { "type": "string", "minLength": 1 },
          "actor":       { "type": "string", "minLength": 1 },
          "requirement": { "type": "string", "pattern": "^REQ-\\d+$" },
          "command":     { "type": "string" },
          "query":       { "type": "string" },
          "aggregate":   { "type": "string", "minLength": 1 },
          "emits":       { "type": "array", "items": { "type": "string" } },
          "scenarios":   { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^SCN-\\d+$" } },
          "status":      { "$ref": "#/$defs/status" }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "use_case", "fields"],
        "additionalProperties": false,
        "properties": {
          "id":       { "type": "string", "pattern": "^CMD-\\d+$" },
          "name":     { "type": "string", "pattern": "^[A-Z][a-zA-Z]+Command$" },
          "use_case": { "type": "string", "pattern": "^UC-\\d+$" },
          "fields":   { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "aggregates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "context", "invariants"],
        "additionalProperties": false,
        "properties": {
          "id":         { "type": "string", "pattern": "^AGG-\\d+$" },
          "name":       { "type": "string", "minLength": 1 },
          "context":    { "type": "string", "minLength": 1 },
          "invariants": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "value_objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "fields", "invariants"],
        "additionalProperties": false,
        "properties": {
          "id":         { "type": "string", "pattern": "^VO-\\d+$" },
          "name":       { "type": "string", "minLength": 1 },
          "fields":     { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "invariants": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "producer", "consumers", "payload"],
        "additionalProperties": false,
        "properties": {
          "id":        { "type": "string", "pattern": "^EVT-\\d+$" },
          "name":      { "type": "string", "minLength": 1 },
          "type":      { "type": "string", "enum": ["domain", "integration"] },
          "producer":  { "type": "string", "minLength": 1 },
          "consumers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "payload":   { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["files"],
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["target", "template"],
            "additionalProperties": false,
            "properties": {
              "target":   { "type": "string", "minLength": 1 },
              "template": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "required": ["traceability"],
      "additionalProperties": false,
      "properties": {
        "traceability": {
          "type": "object",
          "required": ["target", "include_existing_rows", "default_status"],
          "additionalProperties": false,
          "properties": {
            "target":                { "type": "string", "minLength": 1 },
            "include_existing_rows": { "type": "boolean" },
            "default_status":        { "$ref": "#/$defs/status" }
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "requirement_id", "use_case", "seed", "target", "template", "feature", "scenario", "command", "aggregate", "events", "technical_artifacts", "test_artifact", "status"],
        "additionalProperties": false,
        "properties": {
          "id":                   { "type": "string", "pattern": "^SCN-\\d+$" },
          "requirement_id":       { "type": "string", "pattern": "^REQ-\\d+$" },
          "use_case":             { "type": "string", "pattern": "^UC-\\d+$" },
          "seed":                 { "type": "boolean" },
          "target":               { "type": "string", "minLength": 1 },
          "template":             { "type": "string", "minLength": 1 },
          "feature":              { "type": "string", "minLength": 1 },
          "scenario":             { "type": "string", "minLength": 1 },
          "command":              { "type": "string", "minLength": 1 },
          "aggregate":            { "type": "string", "minLength": 1 },
          "events":               { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "technical_artifacts":  { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "test_artifact":        { "type": "string", "minLength": 1 },
          "status":               { "$ref": "#/$defs/status" }
        }
      }
    },
    "api_contracts": {
      "type": "array",
      "description": "REST/GraphQL/event API contracts (contracts project_type only).",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "provider", "consumers", "schema_ref"],
        "additionalProperties": false,
        "properties": {
          "id":         { "type": "string", "pattern": "^AC-\\d+$" },
          "title":      { "type": "string", "minLength": 1 },
          "type":       { "type": "string", "enum": ["REST", "GraphQL", "AsyncAPI", "gRPC"] },
          "provider":   { "type": "string", "minLength": 1 },
          "consumers":  { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "schema_ref": { "type": "string", "minLength": 1 },
          "requirement": { "type": "string", "pattern": "^REQ-\\d+$" }
        }
      }
    },
    "consumer_driven_tests": {
      "type": "array",
      "description": "Pact / consumer-driven contract test definitions (contracts project_type only).",
      "items": {
        "type": "object",
        "required": ["id", "consumer", "provider", "pact_file", "requirement"],
        "additionalProperties": false,
        "properties": {
          "id":        { "type": "string", "pattern": "^CDT-\\d+$" },
          "consumer":  { "type": "string", "minLength": 1 },
          "provider":  { "type": "string", "minLength": 1 },
          "pact_file": { "type": "string", "minLength": 1 },
          "requirement": { "type": "string", "pattern": "^REQ-\\d+$" }
        }
      }
    },
    "breaking_change_rules": {
      "type": "array",
      "description": "Rules that define what constitutes a breaking change for each API contract.",
      "items": {
        "type": "object",
        "required": ["contract_id", "rules"],
        "additionalProperties": false,
        "properties": {
          "contract_id": { "type": "string", "pattern": "^AC-\\d+$" },
          "requirement": { "type": "string", "pattern": "^REQ-\\d+$" },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "if": {
    "properties": {
      "metadata": {
        "properties": {
          "project_type": { "enum": ["backend", "frontend"] }
        }
      }
    }
  },
  "then": {
    "required": [
      "bounded_contexts",
      "use_cases",
      "commands",
      "aggregates",
      "events",
      "scenarios"
    ]
  },
  "else": {
    "required": ["api_contracts"]
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Needs Clarification",
        "Domain Reviewed",
        "Architecture Reviewed",
        "Ready for Dev",
        "In Dev",
        "In Review",
        "Verified",
        "Released",
        "Deprecated"
      ]
    }
  }
}
