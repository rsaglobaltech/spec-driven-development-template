{
  "name": "create-spec-driven-app",
  "version": "0.1.0-beta.3",
  "description": "CLI to scaffold Spec-Driven Development project templates.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "create-spec-driven-app": "bin/create-spec-driven-app.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "templates/",
    "examples/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rsaglobaltech/spec-driven-development-template.git"
  },
  "keywords": [
    "spec-driven-development",
    "sdd",
    "gherkin",
    "templates",
    "scaffolding",
    "cli"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:vscode-unit": "node --test packages/vscode-spec-driven/test/unit/*.test.js",
    "test:mcp-unit": "node --test packages/mcp-spec-driven/test/unit/*.test.js",
    "test:registry-unit": "node --test packages/pack-registry/test/unit/*.test.js",
    "registry:build": "node packages/pack-registry/src/build.js",
    "test:snapshot": "node --test tests/snapshot/*.test.js",
    "snapshot:update": "UPDATE_SNAPSHOTS=1 node --test tests/snapshot/*.test.js",
    "mutation:pilot": "stryker run stryker.config.mjs",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov --lines 75 --branches 65 --functions 80 node --test tests/unit/*.test.js",
    "test:bdd": "cucumber-js",
    "test:all": "npm test && npm run test:coverage && npm run test:bdd && npm run test:vscode-unit && npm run test:mcp-unit && npm run test:registry-unit && npm run test:snapshot && npm run registry:build",
    "pack:dry-run": "npm pack --dry-run",
    "pack": "npm pack",
    "smoke:help": "node bin/create-spec-driven-app.js --help",
    "smoke:init": "node bin/create-spec-driven-app.js init --config examples/project.config.example --out /private/tmp --dry-run --no-git --force",
    "smoke:validate": "node bin/create-spec-driven-app.js validate /private/tmp/acme-energy-hub",
    "smoke:expand": "node bin/create-spec-driven-app.js expand --pack-root tests/fixtures/domain-packs --pack parking-management/backend --project-dir /private/tmp/acme-energy-hub --var PROJECT_NAME='Acme Energy Hub' --var PROJECT_SLUG=acme-energy-hub --var DOMAIN='community energy' --dry-run",
    "lint": "eslint bin/ scripts/ tests/",
    "lint:fix": "eslint --fix bin/ scripts/ tests/",
    "format": "prettier --write bin/ scripts/ tests/",
    "format:check": "prettier --check bin/ scripts/ tests/",
    "verify": "npm run lint && npm test && npm run pack:dry-run"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@eslint/js": "^9.39.4",
    "@stryker-mutator/core": "^9.6.1",
    "ajv": "^8.20.0",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "fast-check": "^4.8.0",
    "prettier": "^3.8.3"
  }
}
